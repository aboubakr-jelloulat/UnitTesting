@model PersonResponseDTO

@{
    ViewData["Title"] = "Delete Contact";
}

<link href="~/css/persons/Index.css" rel="stylesheet" />

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="page-title text-danger mb-0">
            <i class="fa fa-trash me-2"></i> Delete Contact
        </h2>
        <p class="page-subtitle">Please confirm before deleting</p>
    </div>

    <a asp-action="Index" class="btn btn-light border">
        <i class="fa fa-arrow-left"></i> Back
    </a>

</div>

<!-- CARD -->
<div class="bg-white rounded shadow-sm overflow-hidden">

    <!-- WARNING BANNER -->
    <div class="bg-danger-subtle border-bottom p-3 d-flex align-items-center">
        <i class="fa fa-triangle-exclamation text-danger me-2"></i>
        <span class="fw-semibold text-danger">
            This action cannot be undone. Are you sure?
        </span>
    </div>

    <!-- CONTENT -->
    <div class="p-4">

        <!-- GRID INFO -->
        <div class="row g-4">

            <!-- LEFT COLUMN -->
            <div class="col-md-6">

                <div class="mb-3">
                    <small class="text-muted d-block">Full Name</small>
                    <div class="fw-semibold fs-5">@Model.PersonName</div>
                </div>

                <div class="mb-3">
                    <small class="text-muted d-block">Email</small>
                    <div>@Model.Email</div>
                </div>

                <div class="mb-3">
                    <small class="text-muted d-block">Address</small>
                    <div class="text-muted small">
                        @Model.Adress
                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN -->
            <div class="col-md-6">

                <div class="mb-3">
                    <small class="text-muted d-block">Date of Birth</small>
                    <div>
                        @(Model.DateOfBirth?.ToString("dd MMM yyyy") ?? "-")
                    </div>
                </div>

                <div class="mb-3">
                    <small class="text-muted d-block">Gender</small>
                    <div>
                        <span class="badge bg-light text-dark border px-3 py-2">
                            @Model.Gender
                        </span>
                    </div>
                </div>

                <div class="mb-3">
                    <small class="text-muted d-block">Country</small>
                    <div>@Model.Country</div>
                </div>

            </div>

        </div>

    </div>

    <!-- FOOTER ACTIONS -->
    <div class="border-top p-3 d-flex justify-content-between align-items-center">

        <a asp-action="Index" class="btn btn-light border">
            Cancel
        </a>

        <form asp-action="DeleteConfirmed"
              asp-route-id="@Model.Id"
              method="post"
              class="d-inline">

            <button type="submit" class="btn btn-danger px-4">
                <i class="fa fa-trash me-1"></i> Delete Permanently
            </button>

        </form>

    </div>

</div>